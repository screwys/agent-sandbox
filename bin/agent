#!/usr/bin/env bash
set -euo pipefail

script_path="${BASH_SOURCE[0]}"
if command -v readlink >/dev/null 2>&1; then
    script_path="$(readlink -f -- "$script_path" 2>/dev/null || printf '%s\n' "$script_path")"
fi
repo="$(cd -- "$(dirname -- "$script_path")/.." && pwd -P)"
bin="${AGENT_SANDBOX_BIN:-$repo/target/release/agent-sandbox}"

if [ -x "$bin" ]; then
    exec "$bin" agent "$@"
fi

exec cargo run --quiet --manifest-path "$repo/Cargo.toml" --bin agent-sandbox -- agent "$@"
