#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
REPO="${AGENT_REPO:-$(cd "$SCRIPT_DIR/.." && pwd -P)}"
DEFAULT_STATE_DIR="$HOME/.agent-sandbox"

CONFIG_FILE="${AGENT_CONFIG:-$DEFAULT_STATE_DIR/config.env}"
if [ -f "$CONFIG_FILE" ]; then
    # shellcheck disable=SC1090
    . "$CONFIG_FILE"
fi

STATE_DIR="${AGENT_STATE_DIR:-$DEFAULT_STATE_DIR}"
PERMISSIONS_DIR="${AGENT_PERMISSIONS_DIR:-$STATE_DIR/permissions.d}"
if [ -d "$PERMISSIONS_DIR" ]; then
    for permissions_file in "$PERMISSIONS_DIR"/*.env; do
        [ -e "$permissions_file" ] || continue
        # shellcheck disable=SC1090
        . "$permissions_file"
    done
fi

IMAGE="${AGENT_IMAGE:-localhost/agent-sandbox:latest}"
AGENT_HOME="${AGENT_HOME:-$STATE_DIR/home}"
PROJECTS_DIR="${AGENT_PROJECTS_DIR:-$HOME/Projects}"
CONTAINERFILE="${AGENT_CONTAINERFILE:-$REPO/Containerfile}"
CONTAINER_CONTEXT="${AGENT_CONTEXT:-$REPO}"
AGENT_NETWORK="${AGENT_NETWORK:-host}"
AGENT_SANDBOX="${AGENT_SANDBOX:-strict}"
HOST_CONTROL_DIR="${AGENT_HOST_CONTROL_DIR:-$STATE_DIR/host-control}"
SANDBOX_DISABLED_UNTIL_FILE="$HOST_CONTROL_DIR/sandbox-disabled-until"
SANDBOX_DISABLE_MAX_SECONDS="${AGENT_SANDBOX_DISABLE_MAX_SECONDS:-14400}"
DESKTOP_RUN=0

usage() {
    cat <<'EOF'
usage: agent COMMAND [ARG...]

commands:
  build-image             build the local agent sandbox image
  setup-android-sdk       install Android SDK into the agent home
  setup-codex-desktop     build codex-desktop-linux into the agent home
  shell                   open an interactive shell
  codex [ARG...]          run Codex CLI inside the sandbox
  desktop [ARG...]        run Codex Desktop inside the sandbox
  exec COMMAND [ARG...]   run an arbitrary command inside the sandbox
  sandbox off [240m]      allow disabled sandbox mode from a host terminal
  sandbox off --forever
  sandbox on              return to normal sandbox mode
  sandbox status          print sandbox status
  doctor                  print basic readiness checks
EOF
}

need_cmd() {
    command -v "$1" >/dev/null 2>&1 || {
        printf 'missing required command: %s\n' "$1" >&2
        exit 127
    }
}

running_inside_container() {
    [ "${AGENT_FORCE_CONTAINER:-}" = "1" ] && return 0
    [ -f /.dockerenv ] && return 0
    [ -f /run/.containerenv ] && return 0
    [ -n "${container:-}" ] && return 0
    return 1
}

require_host_terminal() {
    if running_inside_container; then
        printf 'sandbox controls must be run from an interactive host terminal\n' >&2
        exit 2
    fi

    if [ "${AGENT_HOST_CONTROL_TEST:-}" = "1" ]; then
        return 0
    fi

    if [ ! -t 0 ] || [ ! -t 1 ]; then
        printf 'sandbox controls must be run from an interactive host terminal\n' >&2
        exit 2
    fi
}

parse_duration_seconds() {
    local duration="${1:-240m}"
    local number
    local unit
    local seconds
    local max_minutes

    if [[ ! "$duration" =~ ^([0-9]+)([smh]?)$ ]]; then
        printf 'invalid duration: %s\n' "$duration" >&2
        printf 'use a value like 240m, 900s, 1m, or --forever\n' >&2
        exit 2
    fi

    number="${BASH_REMATCH[1]}"
    unit="${BASH_REMATCH[2]:-s}"

    case "$unit" in
        s)
            seconds="$number"
            ;;
        m)
            seconds=$((number * 60))
            ;;
        h)
            seconds=$((number * 3600))
            ;;
        *)
            printf 'invalid duration unit: %s\n' "$unit" >&2
            exit 2
            ;;
    esac

    if [ "$seconds" -le 0 ]; then
        printf 'duration must be greater than zero\n' >&2
        exit 2
    fi

    if [ "$seconds" -gt "$SANDBOX_DISABLE_MAX_SECONDS" ]; then
        max_minutes=$((SANDBOX_DISABLE_MAX_SECONDS / 60))
        printf 'sandbox off duration maximum is %sm\n' "$max_minutes" >&2
        exit 2
    fi

    printf '%s\n' "$seconds"
}

sandbox_disabled_until() {
    local until

    [ -f "$SANDBOX_DISABLED_UNTIL_FILE" ] || {
        printf '0\n'
        return 0
    }

    until="$(head -n 1 "$SANDBOX_DISABLED_UNTIL_FILE" 2>/dev/null || true)"
    case "$until" in
        forever)
            printf 'forever\n'
            ;;
        ''|*[!0-9]*)
            printf '0\n'
            ;;
        *)
            printf '%s\n' "$until"
            ;;
    esac
}

sandbox_disable_remaining() {
    local now
    local until

    now="$(date +%s)"
    until="$(sandbox_disabled_until)"

    if [ "$until" = "forever" ]; then
        printf 'forever\n'
        return 0
    fi

    if [ "$until" -gt "$now" ]; then
        printf '%s\n' $((until - now))
    else
        printf '0\n'
    fi
}

sandbox_on_mode_summary() {
    case "$AGENT_SANDBOX" in
        strict|comfortable)
            printf '%s\n' "$AGENT_SANDBOX"
            ;;
        disabled)
            printf 'disabled requested, no off grant\n'
            ;;
        *)
            printf 'invalid mode: %s\n' "$AGENT_SANDBOX"
            ;;
    esac
}

sandbox_lease_summary() {
    local remaining
    local until
    local expires
    local mode_summary

    remaining="$(sandbox_disable_remaining)"
    if [ "$remaining" = "forever" ]; then
        printf 'sandbox: off (forever)\n'
    elif [ "$remaining" -gt 0 ]; then
        until="$(sandbox_disabled_until)"
        expires="$(date -d "@$until" --iso-8601=seconds 2>/dev/null || printf '@%s' "$until")"
        printf 'sandbox: off (%ss remaining, until %s)\n' "$remaining" "$expires"
    else
        mode_summary="$(sandbox_on_mode_summary)"
        printf 'sandbox: on (%s)\n' "$mode_summary"
    fi
}

sandbox_disable() {
    local seconds
    local until

    require_host_terminal
    if [ "${1:-}" = "--forever" ] || [ "${1:-}" = "forever" ]; then
        install -d -m 700 "$STATE_DIR" "$HOST_CONTROL_DIR"
        printf 'forever\n' >"$SANDBOX_DISABLED_UNTIL_FILE"
        chmod 600 "$SANDBOX_DISABLED_UNTIL_FILE"
        sandbox_lease_summary
        return 0
    fi

    seconds="$(parse_duration_seconds "${1:-240m}")"
    until="$(($(date +%s) + seconds))"

    install -d -m 700 "$STATE_DIR" "$HOST_CONTROL_DIR"
    printf '%s\n' "$until" >"$SANDBOX_DISABLED_UNTIL_FILE"
    chmod 600 "$SANDBOX_DISABLED_UNTIL_FILE"
    sandbox_lease_summary
}

sandbox_enable() {
    require_host_terminal
    rm -f "$SANDBOX_DISABLED_UNTIL_FILE"
    sandbox_lease_summary
}

require_active_sandbox_disable() {
    local remaining

    remaining="$(sandbox_disable_remaining)"
    if [ "$remaining" = "forever" ]; then
        require_host_terminal
        return 0
    fi

    if [ "$remaining" -le 0 ]; then
        printf 'sandbox is on; run `agent sandbox off 240m` from a host terminal first\n' >&2
        exit 2
    fi

    require_host_terminal
}

ensure_dirs() {
    case "$AGENT_SANDBOX" in
        comfortable|strict|disabled)
            ;;
        *)
            printf 'invalid AGENT_SANDBOX: %s\n' "$AGENT_SANDBOX" >&2
            printf 'allowed values: comfortable, strict, disabled\n' >&2
            exit 2
            ;;
    esac

    mkdir -p "$AGENT_HOME" \
        "$AGENT_HOME/.cache" \
        "$AGENT_HOME/.codex" \
        "$AGENT_HOME/.config" \
        "$AGENT_HOME/.gradle" \
        "$AGENT_HOME/Android" \
        "$PROJECTS_DIR" \
        "$PERMISSIONS_DIR" \
        "$STATE_DIR"
    if [ "${PROJECTS_DIR#$HOME/}" != "$PROJECTS_DIR" ]; then
        mkdir -p "$AGENT_HOME/${PROJECTS_DIR#$HOME/}"
    fi
    chmod 700 "$AGENT_HOME" "$AGENT_HOME/.codex" "$PERMISSIONS_DIR" "$STATE_DIR"
    if [ ! -f "$AGENT_HOME/.codex/config.toml" ]; then
        cat >"$AGENT_HOME/.codex/config.toml" <<'EOF'
sandbox_mode = "danger-full-access"
approval_policy = "never"

[sandbox_workspace_write]
network_access = true
EOF
        chmod 600 "$AGENT_HOME/.codex/config.toml"
    fi
}

build_image() {
    need_cmd podman
    podman build -t "$IMAGE" -f "$CONTAINERFILE" "$CONTAINER_CONTEXT"
}

image_exists() {
    podman image exists "$IMAGE" >/dev/null 2>&1
}

ensure_image() {
    need_cmd podman
    if ! image_exists; then
        printf 'agent sandbox image %s is missing; building it now\n' "$IMAGE" >&2
        build_image
    fi
}

start_adb_server() {
    if command -v adb >/dev/null 2>&1; then
        adb start-server >/dev/null 2>&1 || true
    fi
}

add_mount_if_exists() {
    local src="$1"
    local dest="${2:-$1}"
    local mode="${3:-rw}"
    if [ -e "$src" ]; then
        PODMAN_ARGS+=(--volume "$src:$dest:$mode")
    fi
}

canonical_path() {
    readlink -f "$1" 2>/dev/null || realpath -m "$1"
}

mount_covers_repo() {
    local src="$1"
    local src_real
    local repo_real

    [ -e "$src" ] || return 1

    src_real="$(canonical_path "$src")"
    repo_real="$(canonical_path "$REPO")"

    [ "$src_real" = "$repo_real" ] && return 0
    case "$repo_real/" in
        "$src_real"/*)
            return 0
            ;;
    esac
    return 1
}

add_extra_mounts() {
    local extra
    local old_ifs
    local -a extra_mounts=()

    [ -n "${AGENT_EXTRA_MOUNTS:-}" ] || return 0

    old_ifs="$IFS"
    IFS=:
    read -r -a extra_mounts <<<"$AGENT_EXTRA_MOUNTS"
    IFS="$old_ifs"

    for extra in "${extra_mounts[@]}"; do
        [ -n "$extra" ] || continue
        if [ "$AGENT_SANDBOX" != "disabled" ] && mount_covers_repo "$extra"; then
            printf 'skipping extra mount that covers protected launcher repo: %s\n' "$extra" >&2
            continue
        fi
        add_mount_if_exists "$extra"
    done
}

mount_projects() {
    local relative
    local protected
    local child

    case "$REPO/" in
        "$PROJECTS_DIR"/*)
            relative="${REPO#$PROJECTS_DIR/}"
            protected="$PROJECTS_DIR/${relative%%/*}"
            while IFS= read -r -d '' child; do
                [ "$child" = "$protected" ] && continue
                add_mount_if_exists "$child"
            done < <(find "$PROJECTS_DIR" -mindepth 1 -maxdepth 1 -print0)
            add_mount_if_exists "$REPO" "$REPO" "ro"
            return 0
            ;;
    esac

    add_mount_if_exists "$PROJECTS_DIR"
}

mount_disabled_filesystems() {
    add_mount_if_exists "$HOME"
    case "$PROJECTS_DIR/" in
        "$HOME"/*)
            ;;
        *)
            add_mount_if_exists "$PROJECTS_DIR"
            ;;
    esac
    add_extra_mounts
    add_mount_if_exists "$STATE_DIR" "$STATE_DIR" "ro"
    add_mount_if_exists "$HOST_CONTROL_DIR" "$HOST_CONTROL_DIR" "ro"
    add_mount_if_exists "$AGENT_HOME" "$AGENT_HOME" "rw"
}

add_desktop_gui_mounts() {
    local host_runtime="${XDG_RUNTIME_DIR:-}"
    local wayland_display="${WAYLAND_DISPLAY:-}"
    local wayland_socket=""
    local pipewire_socket=""
    local pulse_socket=""

    if [ -n "$host_runtime" ] && [ -n "$wayland_display" ]; then
        wayland_socket="$host_runtime/$wayland_display"
        if [ -S "$wayland_socket" ]; then
            PODMAN_ARGS+=(--tmpfs /run/agent-gui:rw,nosuid,nodev,mode=700)
            PODMAN_ARGS+=(--volume "$wayland_socket:/run/agent-gui/$wayland_display:rw")
            PODMAN_ARGS+=(--env "XDG_RUNTIME_DIR=/run/agent-gui")
            PODMAN_ARGS+=(--env "WAYLAND_DISPLAY=$wayland_display")

            pipewire_socket="$host_runtime/pipewire-0"
            if [ -S "$pipewire_socket" ]; then
                PODMAN_ARGS+=(--volume "$pipewire_socket:/run/agent-gui/pipewire-0:rw")
            fi

            pulse_socket="$host_runtime/pulse/native"
            if [ -S "$pulse_socket" ]; then
                PODMAN_ARGS+=(--volume "$pulse_socket:/run/agent-gui/pulse-native:rw")
                PODMAN_ARGS+=(--env "PULSE_SERVER=unix:/run/agent-gui/pulse-native")
            fi
        fi
    fi

    if [ -n "${DISPLAY:-}" ] && [ -d /tmp/.X11-unix ]; then
        PODMAN_ARGS+=(--env "DISPLAY=$DISPLAY")
        PODMAN_ARGS+=(--volume /tmp/.X11-unix:/tmp/.X11-unix:rw)
        if [ -n "${XAUTHORITY:-}" ] && [ -f "$XAUTHORITY" ]; then
            PODMAN_ARGS+=(--env "XAUTHORITY=$XAUTHORITY")
            PODMAN_ARGS+=(--volume "$XAUTHORITY:$XAUTHORITY:ro")
        fi
    fi

    PODMAN_ARGS+=(--env NO_AT_BRIDGE=1)
}

workdir_for_container() {
    case "$PWD/" in
        "$PROJECTS_DIR"/*)
            printf '%s\n' "$PWD"
            ;;
        *)
            printf '%s\n' "$PROJECTS_DIR"
            ;;
    esac
}

run_container() {
    ensure_dirs
    if [ "$AGENT_SANDBOX" = "disabled" ]; then
        require_active_sandbox_disable
    fi
    ensure_image
    start_adb_server

    PODMAN_ARGS=(
        run
        --rm
        --userns=keep-id
        --network="$AGENT_NETWORK"
        --security-opt=no-new-privileges
        --security-opt=label=disable
        --cap-drop=all
        --pids-limit=4096
        --tmpfs /tmp:rw,nosuid,nodev,mode=1777
        --tmpfs /var/tmp:rw,nosuid,nodev,mode=1777
        --env "HOME=$HOME"
        --env "USER=$USER"
        --env "LOGNAME=$USER"
        --env "CODEX_HOME=$HOME/.codex"
        --env "ANDROID_HOME=$HOME/Android/Sdk"
        --env "ANDROID_SDK_ROOT=$HOME/Android/Sdk"
        --env "GRADLE_USER_HOME=$HOME/.gradle"
        --env "ADB_SERVER_SOCKET=tcp:127.0.0.1:5037"
        --workdir "$(workdir_for_container)"
    )
    if [ -n "${AGENT_DESKTOP_COMMAND:-}" ]; then
        PODMAN_ARGS+=(--env "AGENT_DESKTOP_COMMAND=$AGENT_DESKTOP_COMMAND")
    fi
    if [ "$AGENT_SANDBOX" != "disabled" ]; then
        PODMAN_ARGS+=(--read-only)
    fi

    if [ -t 0 ]; then
        PODMAN_ARGS+=(--interactive)
    fi
    if [ -t 0 ] && [ -t 1 ]; then
        PODMAN_ARGS+=(--tty)
    fi

    if [ "$AGENT_SANDBOX" = "disabled" ]; then
        mount_disabled_filesystems
    else
        add_mount_if_exists "$AGENT_HOME" "$HOME" "rw"
        mount_projects
        add_extra_mounts
    fi

    if [ "$DESKTOP_RUN" -eq 1 ]; then
        add_desktop_gui_mounts
    fi

    exec podman "${PODMAN_ARGS[@]}" "$IMAGE" "$@"
}

setup_android_sdk() {
    ensure_dirs
    "$REPO/scripts/setup-android-sdk" "$AGENT_HOME/Android/Sdk" "$@"
}

setup_codex_desktop() {
    run_container "$REPO/scripts/setup-codex-desktop-linux" "$@"
}

run_desktop() {
    DESKTOP_RUN=1
    run_container bash -lc '
set -euo pipefail

if [ -n "${AGENT_DESKTOP_COMMAND:-}" ]; then
    exec ${AGENT_DESKTOP_COMMAND} "$@"
fi

if [ -x "$HOME/.local/share/codex-desktop-linux/codex-app/start.sh" ]; then
    exec "$HOME/.local/share/codex-desktop-linux/codex-app/start.sh" "$@"
fi

for candidate in codex-desktop codex-desktop-linux; do
    if command -v "$candidate" >/dev/null 2>&1; then
        exec "$candidate" "$@"
    fi
done

cat >&2 <<EOF
missing Codex Desktop inside the agent image/home

Run:
  agent setup-codex-desktop

Or set AGENT_DESKTOP_COMMAND to a command available inside the sandbox.
EOF
exit 127
' agent-desktop "$@"
}

doctor() {
    printf 'image: '
    if image_exists; then
        printf 'present (%s)\n' "$IMAGE"
    else
        printf 'missing (%s)\n' "$IMAGE"
    fi
    printf 'agent home: %s\n' "$AGENT_HOME"
    printf 'config file: %s ' "$CONFIG_FILE"
    if [ -f "$CONFIG_FILE" ]; then
        printf '(present)\n'
    else
        printf '(missing)\n'
    fi
    printf 'permissions dir: %s\n' "$PERMISSIONS_DIR"
    printf 'projects mount: %s ' "$PROJECTS_DIR"
    if [ -d "$PROJECTS_DIR" ]; then
        printf '(present)\n'
    else
        printf '(missing)\n'
    fi
    printf 'network: %s\n' "$AGENT_NETWORK"
    printf 'sandbox mode: %s\n' "$AGENT_SANDBOX"
    sandbox_lease_summary
    printf 'adb server: '
    if command -v adb >/dev/null 2>&1 && adb devices >/dev/null 2>&1; then
        printf 'reachable\n'
    else
        printf 'not reachable\n'
    fi
}

cmd="${1:-}"
case "$cmd" in
    build-image)
        build_image
        ;;
    setup-android-sdk)
        shift
        setup_android_sdk "$@"
        ;;
    setup-codex-desktop)
        shift
        setup_codex_desktop "$@"
        ;;
    shell)
        shift
        run_container bash "$@"
        ;;
    codex)
        shift
        run_container codex "$@"
        ;;
    desktop)
        shift
        run_desktop "$@"
        ;;
    exec)
        shift
        [ $# -gt 0 ] || {
            usage >&2
            exit 2
        }
        run_container "$@"
        ;;
    sandbox)
        shift
        sandbox_cmd="${1:-status}"
        case "$sandbox_cmd" in
            off|disable)
                shift
                sandbox_disable "${1:-240m}"
                ;;
            on|enable)
                shift
                sandbox_enable
                ;;
            status|"")
                sandbox_lease_summary
                ;;
            *)
                printf 'unknown sandbox command: %s\n' "$sandbox_cmd" >&2
                usage >&2
                exit 2
                ;;
        esac
        ;;
    doctor)
        doctor
        ;;
    ""|-h|--help|help)
        usage
        ;;
    *)
        printf 'unknown command: %s\n' "$cmd" >&2
        usage >&2
        exit 2
        ;;
esac
