#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
if command -v readlink >/dev/null 2>&1; then
    SCRIPT_PATH="$(readlink -f -- "$SCRIPT_PATH" 2>/dev/null || printf '%s\n' "$SCRIPT_PATH")"
fi
SCRIPT_DIR="$(cd -- "$(dirname -- "$SCRIPT_PATH")" && pwd -P)"
REPO="${AGENT_REPO:-$(cd "$SCRIPT_DIR/.." && pwd -P)}"
DEFAULT_STATE_DIR="$HOME/.agent-sandbox"

CONFIG_FILE="${AGENT_CONFIG:-$DEFAULT_STATE_DIR/config.env}"
if [ -f "$CONFIG_FILE" ]; then
    # shellcheck disable=SC1090
    . "$CONFIG_FILE"
fi

STATE_DIR="${AGENT_STATE_DIR:-$DEFAULT_STATE_DIR}"
PERMISSIONS_DIR="${AGENT_PERMISSIONS_DIR:-$STATE_DIR/permissions.d}"
if [ -d "$PERMISSIONS_DIR" ]; then
    for permissions_file in "$PERMISSIONS_DIR"/*.env; do
        [ -e "$permissions_file" ] || continue
        # shellcheck disable=SC1090
        . "$permissions_file"
    done
fi

IMAGE="${AGENT_IMAGE:-localhost/agent-sandbox:latest}"
AGENT_HOME="${AGENT_HOME:-$STATE_DIR/home}"
PROJECTS_DIR="${AGENT_PROJECTS_DIR:-$HOME/Projects}"
CONTAINERFILE="${AGENT_CONTAINERFILE:-$REPO/Containerfile}"
CONTAINER_CONTEXT="${AGENT_CONTEXT:-$REPO}"
AGENT_NETWORK="${AGENT_NETWORK:-host}"
AGENT_SANDBOX="${AGENT_SANDBOX:-strict}"
AGENT_USERNS="${AGENT_USERNS:-host}"
HOST_CONTROL_DIR="${AGENT_HOST_CONTROL_DIR:-$STATE_DIR/host-control}"
SANDBOX_DISABLED_UNTIL_FILE="$HOST_CONTROL_DIR/sandbox-disabled-until"
SANDBOX_DISABLE_MAX_SECONDS="${AGENT_SANDBOX_DISABLE_MAX_SECONDS:-14400}"
BROKER_DIR="${AGENT_BROKER_DIR:-${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/agent-sandbox}"
BROKER_SOCKET="$BROKER_DIR/broker.sock"

usage() {
    cat <<'EOF'
usage: agent COMMAND [ARG...]

commands:
  build-image             build the local agent sandbox image
  self-update             update the installed checkout if it can fast-forward
  setup-android-sdk       install Android SDK into the agent home
  broker-start            start the host-side user broker
  shell                   open an interactive shell
  codex [ARG...]          run Codex CLI inside the sandbox
  desktop COMMAND ADAPTER manage optional host-side Desktop adapters
  allow PATH [PATH...]    add host folders to the agent mount list
  config [edit|open|path] edit, open, or print the host permission config
  exec COMMAND [ARG...]   run an arbitrary command inside the sandbox
  sandbox off [240m]      allow disabled sandbox mode from a host terminal
  sandbox off --forever
  sandbox on              return to normal sandbox mode
  sandbox status          print sandbox status
  doctor                  print basic readiness checks
EOF
}

desktop_usage() {
    cat <<'EOF'
usage: agent desktop COMMAND ADAPTER

commands:
  detect codex|claude     print detected host package layout
  validate codex|claude   verify a supported host package layout
  install codex|claude    install a host wrapper and .desktop launcher

Desktop adapters are convenience launchers. They run outside the container and
only point supported app subprocesses at sandboxed CLI/app-server commands.
EOF
}

config_file_for_mounts() {
    printf '%s/local.env\n' "$PERMISSIONS_DIR"
}

need_cmd() {
    command -v "$1" >/dev/null 2>&1 || {
        printf 'missing required command: %s\n' "$1" >&2
        exit 127
    }
}

running_inside_container() {
    [ "${AGENT_FORCE_CONTAINER:-}" = "1" ] && return 0
    [ -f /.dockerenv ] && return 0
    [ -f /run/.containerenv ] && return 0
    [ -n "${container:-}" ] && return 0
    return 1
}

require_host_terminal() {
    if running_inside_container; then
        printf 'sandbox controls must be run from an interactive host terminal\n' >&2
        exit 2
    fi

    if [ "${AGENT_HOST_CONTROL_TEST:-}" = "1" ]; then
        return 0
    fi

    if [ ! -t 0 ] || [ ! -t 1 ]; then
        printf 'sandbox controls must be run from an interactive host terminal\n' >&2
        exit 2
    fi
}

require_host_runtime_for_desktop() {
    if running_inside_container; then
        printf 'this command must be run from a host terminal\n' >&2
        return 2
    fi
}

parse_duration_seconds() {
    local duration="${1:-240m}"
    local number
    local unit
    local seconds
    local max_minutes

    if [[ ! "$duration" =~ ^([0-9]+)([smh]?)$ ]]; then
        printf 'invalid duration: %s\n' "$duration" >&2
        printf 'use a value like 240m, 900s, 1m, or --forever\n' >&2
        exit 2
    fi

    number="${BASH_REMATCH[1]}"
    unit="${BASH_REMATCH[2]:-s}"

    case "$unit" in
        s)
            seconds="$number"
            ;;
        m)
            seconds=$((number * 60))
            ;;
        h)
            seconds=$((number * 3600))
            ;;
        *)
            printf 'invalid duration unit: %s\n' "$unit" >&2
            exit 2
            ;;
    esac

    if [ "$seconds" -le 0 ]; then
        printf 'duration must be greater than zero\n' >&2
        exit 2
    fi

    if [ "$seconds" -gt "$SANDBOX_DISABLE_MAX_SECONDS" ]; then
        max_minutes=$((SANDBOX_DISABLE_MAX_SECONDS / 60))
        printf 'sandbox off duration maximum is %sm\n' "$max_minutes" >&2
        exit 2
    fi

    printf '%s\n' "$seconds"
}

sandbox_disabled_until() {
    local until

    [ -f "$SANDBOX_DISABLED_UNTIL_FILE" ] || {
        printf '0\n'
        return 0
    }

    until="$(head -n 1 "$SANDBOX_DISABLED_UNTIL_FILE" 2>/dev/null || true)"
    case "$until" in
        forever)
            printf 'forever\n'
            ;;
        ''|*[!0-9]*)
            printf '0\n'
            ;;
        *)
            printf '%s\n' "$until"
            ;;
    esac
}

sandbox_disable_remaining() {
    local now
    local until

    now="$(date +%s)"
    until="$(sandbox_disabled_until)"

    if [ "$until" = "forever" ]; then
        printf 'forever\n'
        return 0
    fi

    if [ "$until" -gt "$now" ]; then
        printf '%s\n' $((until - now))
    else
        printf '0\n'
    fi
}

sandbox_on_mode_summary() {
    case "$AGENT_SANDBOX" in
        strict|comfortable)
            printf '%s\n' "$AGENT_SANDBOX"
            ;;
        disabled)
            printf 'disabled requested, no off grant\n'
            ;;
        *)
            printf 'invalid mode: %s\n' "$AGENT_SANDBOX"
            ;;
    esac
}

sandbox_lease_summary() {
    local remaining
    local until
    local expires
    local mode_summary

    remaining="$(sandbox_disable_remaining)"
    if [ "$remaining" = "forever" ]; then
        printf 'sandbox: off (forever)\n'
    elif [ "$remaining" -gt 0 ]; then
        until="$(sandbox_disabled_until)"
        expires="$(date -d "@$until" --iso-8601=seconds 2>/dev/null || printf '@%s' "$until")"
        printf 'sandbox: off (%ss remaining, until %s)\n' "$remaining" "$expires"
    else
        mode_summary="$(sandbox_on_mode_summary)"
        printf 'sandbox: on (%s)\n' "$mode_summary"
    fi
}

sandbox_disable() {
    local seconds
    local until

    require_host_terminal
    if [ "${1:-}" = "--forever" ] || [ "${1:-}" = "forever" ]; then
        install -d -m 700 "$STATE_DIR" "$HOST_CONTROL_DIR"
        printf 'forever\n' >"$SANDBOX_DISABLED_UNTIL_FILE"
        chmod 600 "$SANDBOX_DISABLED_UNTIL_FILE"
        sandbox_lease_summary
        return 0
    fi

    seconds="$(parse_duration_seconds "${1:-240m}")"
    until="$(($(date +%s) + seconds))"

    install -d -m 700 "$STATE_DIR" "$HOST_CONTROL_DIR"
    printf '%s\n' "$until" >"$SANDBOX_DISABLED_UNTIL_FILE"
    chmod 600 "$SANDBOX_DISABLED_UNTIL_FILE"
    sandbox_lease_summary
}

sandbox_enable() {
    require_host_terminal
    rm -f "$SANDBOX_DISABLED_UNTIL_FILE"
    sandbox_lease_summary
}

require_active_sandbox_disable() {
    local remaining

    remaining="$(sandbox_disable_remaining)"
    if [ "$remaining" = "forever" ]; then
        require_host_terminal
        return 0
    fi

    if [ "$remaining" -le 0 ]; then
        printf 'sandbox is on; run `agent sandbox off 240m` from a host terminal first\n' >&2
        exit 2
    fi

    require_host_terminal
}

ensure_dirs() {
    case "$AGENT_SANDBOX" in
        comfortable|strict|disabled)
            ;;
        *)
            printf 'invalid AGENT_SANDBOX: %s\n' "$AGENT_SANDBOX" >&2
            printf 'allowed values: comfortable, strict, disabled\n' >&2
            exit 2
            ;;
    esac

    mkdir -p "$AGENT_HOME" \
        "$AGENT_HOME/.cache" \
        "$AGENT_HOME/.codex" \
        "$AGENT_HOME/.config" \
        "$AGENT_HOME/.gradle" \
        "$AGENT_HOME/Android" \
        "$PROJECTS_DIR" \
        "$PERMISSIONS_DIR" \
        "$STATE_DIR"
    if [ "${PROJECTS_DIR#$HOME/}" != "$PROJECTS_DIR" ]; then
        mkdir -p "$AGENT_HOME/${PROJECTS_DIR#$HOME/}"
    fi
    chmod 700 "$AGENT_HOME" "$AGENT_HOME/.codex" "$PERMISSIONS_DIR" "$STATE_DIR"
    if [ ! -f "$AGENT_HOME/.codex/config.toml" ]; then
        cat >"$AGENT_HOME/.codex/config.toml" <<'EOF'
sandbox_mode = "danger-full-access"
approval_policy = "never"

[sandbox_workspace_write]
network_access = true
EOF
        chmod 600 "$AGENT_HOME/.codex/config.toml"
    fi
}

build_image() {
    need_cmd podman
    podman build -t "$IMAGE" -f "$CONTAINERFILE" "$CONTAINER_CONTEXT"
}

self_update() {
    local quiet=0
    local before
    local after
    local upstream
    local changed_files
    local -a pull_args=(pull --ff-only)

    case "${1:-}" in
        --quiet)
            quiet=1
            shift
            ;;
    esac

    [ "$#" -eq 0 ] || {
        printf 'usage: agent self-update [--quiet]\n' >&2
        return 2
    }

    require_host_runtime_for_desktop
    need_cmd git

    if [ ! -d "$REPO/.git" ]; then
        [ "$quiet" -eq 1 ] || printf 'self-update skipped: not a git checkout: %s\n' "$REPO"
        return 0
    fi

    if [ -n "$(git -C "$REPO" status --porcelain --untracked-files=normal)" ]; then
        [ "$quiet" -eq 1 ] || printf 'self-update skipped: checkout has local changes: %s\n' "$REPO"
        return 0
    fi

    if ! upstream="$(git -C "$REPO" rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null)"; then
        [ "$quiet" -eq 1 ] || printf 'self-update skipped: no upstream branch configured: %s\n' "$REPO"
        return 0
    fi

    before="$(git -C "$REPO" rev-parse HEAD)"
    [ "$quiet" -eq 1 ] && pull_args+=(--quiet)
    if ! git -C "$REPO" "${pull_args[@]}"; then
        printf 'self-update failed: could not fast-forward from %s\n' "$upstream" >&2
        return 1
    fi
    after="$(git -C "$REPO" rev-parse HEAD)"

    if [ "$before" = "$after" ]; then
        [ "$quiet" -eq 1 ] || printf 'self-update: already up to date\n'
        return 0
    fi

    [ "$quiet" -eq 1 ] || printf 'self-update: updated %s..%s\n' "${before:0:12}" "${after:0:12}"

    if command -v systemctl >/dev/null 2>&1; then
        systemctl --user daemon-reload >/dev/null 2>&1 || true
    fi

    changed_files="$(git -C "$REPO" diff --name-only "$before" "$after" -- || true)"
    if printf '%s\n' "$changed_files" |
        grep -Eq '^(Containerfile|bin/agent-host|bin/wrappers/systemctl|bin/wrappers/journalctl)$'; then
        if command -v podman >/dev/null 2>&1; then
            build_image || printf 'WARN: self-update could not rebuild the sandbox image\n' >&2
        else
            printf 'WARN: self-update changed image files, but podman is missing\n' >&2
        fi
    fi
}

image_exists() {
    podman image exists "$IMAGE" >/dev/null 2>&1
}

ensure_image() {
    need_cmd podman
    if ! image_exists; then
        printf 'agent sandbox image %s is missing; building it now\n' "$IMAGE" >&2
        build_image
    fi
}

start_adb_server() {
    if command -v adb >/dev/null 2>&1; then
        adb start-server >/dev/null 2>&1 || true
    fi
}

start_broker() {
    local i

    if command -v systemctl >/dev/null 2>&1; then
        systemctl --user start agent-sandbox-broker.service >/dev/null 2>&1 || true
    fi
    i=0
    while [ "$i" -lt 20 ]; do
        [ -S "$BROKER_SOCKET" ] && return 0
        i=$((i + 1))
        sleep 0.05
    done
}

add_mount_if_exists() {
    local src="$1"
    local dest="${2:-$1}"
    local mode="${3:-rw}"
    if [ -e "$src" ]; then
        PODMAN_ARGS+=(--volume "$src:$dest:$mode")
    fi
}

canonical_path() {
    readlink -f "$1" 2>/dev/null || realpath -m "$1"
}

mount_covers_repo() {
    local src="$1"
    local src_real
    local repo_real

    [ -e "$src" ] || return 1

    src_real="$(canonical_path "$src")"
    repo_real="$(canonical_path "$REPO")"

    [ "$src_real" = "$repo_real" ] && return 0
    case "$repo_real/" in
        "$src_real"/*)
            return 0
            ;;
    esac
    return 1
}

add_extra_mounts() {
    local extra
    local old_ifs
    local -a extra_mounts=()

    [ -n "${AGENT_EXTRA_MOUNTS:-}" ] || return 0

    old_ifs="$IFS"
    IFS=:
    read -r -a extra_mounts <<<"$AGENT_EXTRA_MOUNTS"
    IFS="$old_ifs"

    for extra in "${extra_mounts[@]}"; do
        [ -n "$extra" ] || continue
        if [ "$AGENT_SANDBOX" != "disabled" ] && mount_covers_repo "$extra"; then
            printf 'skipping extra mount that covers protected launcher repo: %s\n' "$extra" >&2
            continue
        fi
        add_mount_if_exists "$extra"
    done
}

mount_projects() {
    local relative
    local protected
    local child

    case "$REPO/" in
        "$PROJECTS_DIR"/*)
            relative="${REPO#$PROJECTS_DIR/}"
            protected="$PROJECTS_DIR/${relative%%/*}"
            while IFS= read -r -d '' child; do
                [ "$child" = "$protected" ] && continue
                add_mount_if_exists "$child"
            done < <(find "$PROJECTS_DIR" -mindepth 1 -maxdepth 1 -print0)
            add_mount_if_exists "$REPO" "$REPO" "ro"
            return 0
            ;;
    esac

    add_mount_if_exists "$PROJECTS_DIR"
}

mount_disabled_filesystems() {
    add_mount_if_exists "$HOME"
    case "$PROJECTS_DIR/" in
        "$HOME"/*)
            ;;
        *)
            add_mount_if_exists "$PROJECTS_DIR"
            ;;
    esac
    add_extra_mounts
    add_mount_if_exists "$STATE_DIR" "$STATE_DIR" "ro"
    add_mount_if_exists "$HOST_CONTROL_DIR" "$HOST_CONTROL_DIR" "ro"
    add_mount_if_exists "$BROKER_DIR" "/run/agent-sandbox" "rw"
    add_mount_if_exists "$AGENT_HOME" "$AGENT_HOME" "rw"
}

workdir_for_container() {
    case "$PWD/" in
        "$PROJECTS_DIR"/*)
            printf '%s\n' "$PWD"
            ;;
        *)
            printf '%s\n' "$PROJECTS_DIR"
            ;;
    esac
}

run_container() {
    ensure_dirs
    if [ "$AGENT_SANDBOX" = "disabled" ]; then
        require_active_sandbox_disable
    fi
    ensure_image
    start_broker
    start_adb_server

    PODMAN_ARGS=(
        run
        --rm
        --userns="$AGENT_USERNS"
        --network="$AGENT_NETWORK"
        --security-opt=no-new-privileges
        --security-opt=label=disable
        --cap-drop=all
        --pids-limit=4096
        --tmpfs /tmp:rw,nosuid,nodev,mode=1777
        --tmpfs /var/tmp:rw,nosuid,nodev,mode=1777
        --tmpfs /root/.android:rw,nosuid,nodev,mode=700
        --env "HOME=$HOME"
        --env "USER=$USER"
        --env "LOGNAME=$USER"
        --env "CODEX_HOME=$HOME/.codex"
        --env "ANDROID_HOME=$HOME/Android/Sdk"
        --env "ANDROID_SDK_ROOT=$HOME/Android/Sdk"
        --env "ANDROID_USER_HOME=$HOME/.android"
        --env "GRADLE_USER_HOME=$HOME/.gradle"
        --env "GRADLE_OPTS=-Duser.home=$HOME ${GRADLE_OPTS:-}"
        --env "ADB_SERVER_SOCKET=tcp:127.0.0.1:5037"
        --env "AGENT_BROKER_SOCKET=/run/agent-sandbox/broker.sock"
        --workdir "$(workdir_for_container)"
    )
    if [ "$AGENT_SANDBOX" != "disabled" ]; then
        PODMAN_ARGS+=(--read-only)
    fi

    if [ -t 0 ] || [ "${AGENT_PRESERVE_STDIN:-}" = "1" ]; then
        PODMAN_ARGS+=(--interactive)
    fi
    if [ -t 0 ] && [ -t 1 ]; then
        PODMAN_ARGS+=(--tty)
    fi

    if [ "$AGENT_SANDBOX" = "disabled" ]; then
        mount_disabled_filesystems
    else
        add_mount_if_exists "$AGENT_HOME" "$HOME" "rw"
        add_mount_if_exists "$BROKER_DIR" "/run/agent-sandbox" "rw"
        mount_projects
        add_extra_mounts
    fi

    exec podman "${PODMAN_ARGS[@]}" "$IMAGE" "$@"
}

setup_android_sdk() {
    ensure_dirs
    "$REPO/scripts/setup-android-sdk" "$AGENT_HOME/Android/Sdk" "$@"
}

desktop_host_path() {
    printf '%s%s\n' "${AGENT_DESKTOP_ROOT:-}" "$1"
}

desktop_dest_bin() {
    case "$1" in
        codex)
            printf '%s/.local/bin/codex-desktop-sandboxed\n' "$HOME"
            ;;
        claude)
            printf '%s/.local/bin/claude-desktop-sandboxed\n' "$HOME"
            ;;
        *)
            return 1
            ;;
    esac
}

desktop_dest_entry() {
    case "$1" in
        codex)
            printf '%s/.local/share/applications/codex-sandboxed.desktop\n' "$HOME"
            ;;
        claude)
            printf '%s/.local/share/applications/claude-sandboxed.desktop\n' "$HOME"
            ;;
        *)
            return 1
            ;;
    esac
}

desktop_set_codex_paths() {
    local user_appdir="${AGENT_CODEX_DESKTOP_USER_APPDIR:-$HOME/.local/opt/codex-desktop-linux/codex-app}"
    local system_appdir
    local system_launcher

    system_appdir="$(desktop_host_path /usr/lib/openai-codex-desktop)"
    system_launcher="$(desktop_host_path /usr/bin/codex-desktop)"

    CODEX_ADAPTER_LAYOUT="${AGENT_CODEX_DESKTOP_LAYOUT:-system}"
    CODEX_ADAPTER_APPDIR="${AGENT_CODEX_DESKTOP_APPDIR:-$system_appdir}"
    CODEX_ADAPTER_ELECTRON="${AGENT_CODEX_DESKTOP_ELECTRON:-$(desktop_host_path /usr/lib/electron39/electron)}"
    CODEX_ADAPTER_SYSTEM_LAUNCHER="${AGENT_CODEX_DESKTOP_SYSTEM_LAUNCHER:-$system_launcher}"
    CODEX_ADAPTER_START_SH=""

    if [ -z "${AGENT_CODEX_DESKTOP_APPDIR:-}" ] &&
        [ -f "$user_appdir/resources/app.asar" ]; then
        CODEX_ADAPTER_LAYOUT="user-local"
        CODEX_ADAPTER_APPDIR="$user_appdir"
        CODEX_ADAPTER_ELECTRON="${AGENT_CODEX_DESKTOP_ELECTRON:-$user_appdir/electron}"
        CODEX_ADAPTER_SYSTEM_LAUNCHER="${AGENT_CODEX_DESKTOP_SYSTEM_LAUNCHER:-$user_appdir/start.sh}"
        CODEX_ADAPTER_START_SH="$user_appdir/start.sh"
    fi

    CODEX_ADAPTER_ASAR="$CODEX_ADAPTER_APPDIR/resources/app.asar"
    CODEX_ADAPTER_WEBVIEW="$CODEX_ADAPTER_APPDIR/content/webview"
    CODEX_ADAPTER_CLI_PATH="${AGENT_CODEX_CLI_PATH:-$HOME/.local/bin/agent-codex}"
    CODEX_ADAPTER_CONFIG_HOME="${AGENT_CODEX_DESKTOP_CONFIG_HOME:-$HOME/.config/codex-sandboxed}"
    CODEX_ADAPTER_STATE_HOME="${AGENT_CODEX_DESKTOP_STATE_HOME:-$HOME/.local/state/codex-sandboxed}"
    CODEX_ADAPTER_CACHE_HOME="${AGENT_CODEX_DESKTOP_CACHE_HOME:-$HOME/.cache/codex-sandboxed}"
    CODEX_ADAPTER_PORT="${AGENT_CODEX_DESKTOP_WEBVIEW_PORT:-5176}"
}

desktop_codex_supported_layout() {
    desktop_set_codex_paths
    cat <<EOF
supported layouts:
  layout: $CODEX_ADAPTER_LAYOUT
  system launcher: $CODEX_ADAPTER_SYSTEM_LAUNCHER (optional)
  electron: $CODEX_ADAPTER_ELECTRON
  app asar: $CODEX_ADAPTER_ASAR
  webview dir: $CODEX_ADAPTER_WEBVIEW
  sandboxed CLI: $CODEX_ADAPTER_CLI_PATH
  profile/config dir: $CODEX_ADAPTER_CONFIG_HOME
  state dir: $CODEX_ADAPTER_STATE_HOME
  cache dir: $CODEX_ADAPTER_CACHE_HOME
  webview port: $CODEX_ADAPTER_PORT
EOF
}

desktop_codex_validation_errors() {
    local failed=0

    desktop_set_codex_paths

    if [ ! -x "$CODEX_ADAPTER_ELECTRON" ]; then
        printf '  missing executable: %s\n' "$CODEX_ADAPTER_ELECTRON"
        failed=1
    fi
    if [ ! -f "$CODEX_ADAPTER_ASAR" ]; then
        printf '  missing app asar: %s\n' "$CODEX_ADAPTER_ASAR"
        failed=1
    fi
    if [ ! -d "$CODEX_ADAPTER_WEBVIEW" ]; then
        printf '  missing webview dir: %s\n' "$CODEX_ADAPTER_WEBVIEW"
        failed=1
    elif ! find "$CODEX_ADAPTER_WEBVIEW" -mindepth 1 -maxdepth 1 -print -quit | grep -q .; then
        printf '  empty webview dir: %s\n' "$CODEX_ADAPTER_WEBVIEW"
        failed=1
    fi
    if [ "$CODEX_ADAPTER_LAYOUT" = "user-local" ]; then
        if [ -n "$CODEX_ADAPTER_START_SH" ] && [ ! -x "$CODEX_ADAPTER_START_SH" ]; then
            printf '  missing executable start script: %s\n' "$CODEX_ADAPTER_START_SH"
            failed=1
        fi
    elif [ "$CODEX_ADAPTER_LAYOUT" = "system" ]; then
        :
    else
        printf '  unknown Codex Desktop layout: %s\n' "$CODEX_ADAPTER_LAYOUT"
        failed=1
    fi

    if [ ! -x "$CODEX_ADAPTER_CLI_PATH" ]; then
        printf '  missing sandboxed CLI executable: %s\n' "$CODEX_ADAPTER_CLI_PATH"
        failed=1
    fi

    return "$failed"
}

desktop_codex_detect() {
    local errors=""
    local status="experimental"

    if ! errors="$(desktop_codex_validation_errors)"; then
        status="unsupported"
    fi

    desktop_set_codex_paths
    cat <<EOF
adapter: codex
status: $status
electron: host-native
app-server: CODEX_CLI_PATH points at agent-codex
shared local chats: no
experimental: yes, package-specific host wrapper
layout: $CODEX_ADAPTER_LAYOUT
system launcher: $CODEX_ADAPTER_SYSTEM_LAUNCHER
electron: $CODEX_ADAPTER_ELECTRON
app asar: $CODEX_ADAPTER_ASAR
webview dir: $CODEX_ADAPTER_WEBVIEW
sandboxed CLI: $CODEX_ADAPTER_CLI_PATH
profile/config dir: $CODEX_ADAPTER_CONFIG_HOME
state dir: $CODEX_ADAPTER_STATE_HOME
cache dir: $CODEX_ADAPTER_CACHE_HOME
webview port: $CODEX_ADAPTER_PORT
wrapper: $(desktop_dest_bin codex)
desktop entry: $(desktop_dest_entry codex)
EOF
    if [ -n "$errors" ]; then
        printf 'detected problems:\n%s\n' "$errors"
    fi
}

desktop_codex_validate() {
    local errors=""

    if ! errors="$(desktop_codex_validation_errors)"; then
        printf 'unsupported Codex Desktop package layout\n\n' >&2
        desktop_codex_supported_layout >&2
        printf '\ndetected problems:\n%s\n' "$errors" >&2
        printf '\nCodex Desktop support is experimental and limited to known package layouts.\n' >&2
        printf 'Electron stays host-native; only the Codex CLI/app-server path is redirected into Podman.\n' >&2
        return 2
    fi

    printf 'Codex Desktop adapter validation passed (experimental)\n'
}

write_codex_wrapper() {
    local wrapper

    desktop_set_codex_paths
    wrapper="$(desktop_dest_bin codex)"
    install -d -m 755 "$(dirname "$wrapper")"
    cat >"$wrapper" <<EOF
#!/usr/bin/env bash
set -euo pipefail

electron="$CODEX_ADAPTER_ELECTRON"
app_asar="$CODEX_ADAPTER_ASAR"
appdir="$CODEX_ADAPTER_APPDIR"
webview_dir="$CODEX_ADAPTER_WEBVIEW"
webview_port="\${AGENT_CODEX_DESKTOP_WEBVIEW_PORT:-$CODEX_ADAPTER_PORT}"
layout="$CODEX_ADAPTER_LAYOUT"
start_sh="$CODEX_ADAPTER_START_SH"

export CODEX_CLI_PATH="\${CODEX_CLI_PATH:-$CODEX_ADAPTER_CLI_PATH}"
export CODEX_LINUX_CLI_PATH="\${CODEX_LINUX_CLI_PATH:-\${CODEX_CLI_PATH}}"
export CUSTOM_CLI_PATH="\${CUSTOM_CLI_PATH:-\${CODEX_CLI_PATH}}"
export XDG_CONFIG_HOME="\${XDG_CONFIG_HOME:-$CODEX_ADAPTER_CONFIG_HOME}"
export XDG_STATE_HOME="\${XDG_STATE_HOME:-$CODEX_ADAPTER_STATE_HOME}"
export XDG_CACHE_HOME="\${XDG_CACHE_HOME:-$CODEX_ADAPTER_CACHE_HOME}"
export BUILD_FLAVOR="\${BUILD_FLAVOR:-prod}"
export NODE_ENV="\${NODE_ENV:-production}"
export LD_PRELOAD="\${AGENT_CODEX_DESKTOP_LD_PRELOAD-}"
export ELECTRON_RENDERER_URL="\${ELECTRON_RENDERER_URL:-http://127.0.0.1:\${webview_port}/}"
export CODEX_WEBVIEW_PORT="\${CODEX_WEBVIEW_PORT:-\${webview_port}}"
EOF
    cat >>"$wrapper" <<'EOF'

[[ -x "${electron}" ]] || {
  echo "missing Electron runtime: ${electron}" >&2
  exit 1
}
[[ -f "${app_asar}" ]] || {
  echo "missing Codex Desktop app: ${app_asar}" >&2
  exit 1
}
[[ -x "${CODEX_CLI_PATH}" ]] || {
  echo "missing sandboxed Codex CLI: ${CODEX_CLI_PATH}" >&2
  echo "run scripts/install.sh or set CODEX_CLI_PATH explicitly" >&2
  exit 127
}

mkdir -p "${XDG_CONFIG_HOME}" "${XDG_STATE_HOME}" "${XDG_CACHE_HOME}"

if [[ "${layout}" == "user-local" && -x "${start_sh}" ]]; then
  tmp_start="$(mktemp "${appdir%/}/.agent-sandbox-start.XXXXXX")"

  {
    printf '#!/usr/bin/env bash\n'
    printf 'rm -f "$0"\n'
    sed \
    -e 's/^CODEX_LINUX_APP_ID=.*/CODEX_LINUX_APP_ID=Codex/' \
    -e 's/^CODEX_LINUX_APP_DISPLAY_NAME=.*/CODEX_LINUX_APP_DISPLAY_NAME=CodexSandboxed/' \
      "${start_sh}"
  } >"${tmp_start}"
  chmod +x "${tmp_start}"
  exec "${tmp_start}" "$@"
fi

http_pid=""
electron_pid=""
tmpdir=""

cleanup() {
  [[ -n "${electron_pid}" ]] && wait "${electron_pid}" 2>/dev/null || true
  [[ -n "${http_pid}" ]] && kill "${http_pid}" 2>/dev/null || true
  [[ -n "${http_pid}" ]] && wait "${http_pid}" 2>/dev/null || true
  [[ -n "${tmpdir}" ]] && rm -rf "${tmpdir}"
}

forward_signal() {
  local sig="$1"

  if [[ -n "${electron_pid}" ]] && kill -0 "${electron_pid}" 2>/dev/null; then
    kill -"${sig}" "${electron_pid}" 2>/dev/null || true
    wait "${electron_pid}" 2>/dev/null || true
  fi

  exit 0
}

trap cleanup EXIT
trap 'forward_signal HUP' HUP
trap 'forward_signal INT' INT
trap 'forward_signal TERM' TERM

if [[ -d "${webview_dir}" ]] && find "${webview_dir}" -mindepth 1 -maxdepth 1 -print -quit | grep -q .; then
  python_cmd="${PYTHON:-}"
  if [[ -z "${python_cmd}" ]]; then
    python_cmd="$(command -v python3 || command -v python || true)"
  fi
  [[ -n "${python_cmd}" ]] || {
    echo "missing python or python3 for local Codex webview server" >&2
    exit 127
  }

  tmpdir="$(mktemp -d)"
  ready_file="${tmpdir}/ready"
  fail_file="${tmpdir}/fail"

  "${python_cmd}" - "${webview_port}" "${webview_dir}" "${ready_file}" "${fail_file}" >/dev/null 2>&1 <<'PY' &
import http.server
import os
import socketserver
import sys

port = int(sys.argv[1])
root = sys.argv[2]
ready_file = sys.argv[3]
fail_file = sys.argv[4]

os.chdir(root)

class Handler(http.server.SimpleHTTPRequestHandler):
    def log_message(self, fmt, *args):
        pass

class TCPServer(socketserver.TCPServer):
    allow_reuse_address = True

try:
    with TCPServer(("127.0.0.1", port), Handler) as httpd:
        with open(ready_file, "w") as f:
            f.write("ok")
        httpd.serve_forever()
except Exception as e:
    with open(fail_file, "w") as f:
        f.write(str(e))
    raise
PY
  http_pid=$!

  for _ in {1..50}; do
    [[ -f "${ready_file}" ]] && break
    if [[ -f "${fail_file}" ]]; then
      echo "failed to start local webview server on 127.0.0.1:${webview_port}" >&2
      cat "${fail_file}" >&2
      exit 1
    fi
    kill -0 "${http_pid}" 2>/dev/null || {
      echo "local webview server exited before becoming ready" >&2
      exit 1
    }
    sleep 0.1
  done

  [[ -f "${ready_file}" ]] || {
    echo "timed out waiting for local webview server on 127.0.0.1:${webview_port}" >&2
    exit 1
  }
fi

if [[ "${layout}" == "user-local" ]]; then
  "${electron}" \
    --no-sandbox \
    --disable-dev-shm-usage \
    --disable-gpu-sandbox \
    --disable-gpu-compositing \
    --ozone-platform-hint=auto \
    --app-id=Codex \
    --class=Codex \
    "${app_asar}" \
    "$@" &
else
  "${electron}" \
    --enable-sandbox \
    --ozone-platform-hint=auto \
    --app-id=Codex \
    --class=Codex \
    "${app_asar}" \
    "$@" &
fi
electron_pid=$!
wait "${electron_pid}"
EOF
    chmod 755 "$wrapper"
}

write_desktop_entry() {
    local adapter="$1"
    local entry
    local wrapper
    local name
    local comment
    local icon
    local wmclass

    entry="$(desktop_dest_entry "$adapter")"
    wrapper="$(desktop_dest_bin "$adapter")"
    case "$adapter" in
        codex)
            name="Codex (Sandboxed)"
            comment="Codex Desktop with sandboxed Codex CLI app-server"
            icon="openai-codex-desktop"
            wmclass="Codex"
            ;;
        claude)
            name="Claude Desktop (Sandboxed)"
            comment="Claude Desktop with sandboxed agent subprocesses"
            icon="claude"
            wmclass="Claude"
            ;;
        *)
            return 1
            ;;
    esac

    install -d -m 755 "$(dirname "$entry")"
    cat >"$entry" <<EOF
[Desktop Entry]
Type=Application
Name=$name
Comment=$comment
Exec=$wrapper %U
Icon=$icon
Categories=Development;IDE;
Terminal=false
StartupNotify=true
StartupWMClass=$wmclass
EOF
    chmod 644 "$entry"
}

desktop_codex_install() {
    desktop_codex_validate >/dev/null
    write_codex_wrapper
    write_desktop_entry codex
    printf 'installed Codex Desktop adapter (experimental)\n'
    printf 'wrapper: %s\n' "$(desktop_dest_bin codex)"
    printf 'desktop entry: %s\n' "$(desktop_dest_entry codex)"
    printf 'Electron stays host-native; Codex CLI/app-server uses %s\n' "$CODEX_ADAPTER_CLI_PATH"
}

desktop_claude_supported_layout() {
    cat <<'EOF'
supported exact layout:
  none registered
EOF
}

desktop_claude_detect() {
    cat <<EOF
adapter: claude
status: unsupported
electron: host-native if a future supported Desktop layout is added
shared local chats: no
wrapper: $(desktop_dest_bin claude)
desktop entry: $(desktop_dest_entry claude)

detected problems:
  no supported Claude Desktop package layout is registered yet
  no stable launcher contract for CLI path, profile/config dir, or app-server transport is known
EOF
}

desktop_claude_validate() {
    printf 'unsupported Claude Desktop package layout\n\n' >&2
    desktop_claude_supported_layout >&2
    printf '\ndetected problems:\n' >&2
    printf '  no supported Claude Desktop package layout is registered yet\n' >&2
    printf '  no stable launcher contract for CLI path, profile/config dir, or app-server transport is known\n' >&2
    return 2
}

desktop_claude_install() {
    desktop_claude_validate
}

desktop_cmd() {
    local subcmd="${1:-}"
    local adapter="${2:-}"

    case "$subcmd" in
        detect|validate|install)
            ;;
        ""|-h|--help|help)
            desktop_usage
            return 0
            ;;
        *)
            printf 'unknown desktop command: %s\n' "$subcmd" >&2
            desktop_usage >&2
            return 2
            ;;
    esac

    require_host_runtime_for_desktop

    case "$adapter" in
        codex|claude)
            ;;
        "")
            printf 'missing desktop adapter\n' >&2
            desktop_usage >&2
            return 2
            ;;
        *)
            printf 'unknown desktop adapter: %s\n' "$adapter" >&2
            printf 'supported adapters: codex, claude\n' >&2
            return 2
            ;;
    esac

    case "$subcmd:$adapter" in
        detect:codex)
            desktop_codex_detect
            ;;
        validate:codex)
            desktop_codex_validate
            ;;
        install:codex)
            desktop_codex_install
            ;;
        detect:claude)
            desktop_claude_detect
            ;;
        validate:claude)
            desktop_claude_validate
            ;;
        install:claude)
            desktop_claude_install
            ;;
    esac
}

load_configured_mounts() {
    local file

    file="$(config_file_for_mounts)"
    [ -f "$file" ] || return 0

    (
        AGENT_EXTRA_MOUNTS=""
        # shellcheck disable=SC1090
        . "$file"
        printf '%s\n' "${AGENT_EXTRA_MOUNTS:-}"
    )
}

write_configured_mounts() {
    local mounts="$1"
    local file

    file="$(config_file_for_mounts)"
    install -d -m 700 "$PERMISSIONS_DIR"
    cat >"$file" <<EOF
# edited by agent allow
AGENT_EXTRA_MOUNTS=$(printf '%q' "$mounts")
EOF
    chmod 600 "$file"
}

mount_list_contains() {
    local list="$1"
    local item="$2"
    local old_ifs
    local mount
    local -a mounts=()

    old_ifs="$IFS"
    IFS=:
    read -r -a mounts <<<"$list"
    IFS="$old_ifs"

    for mount in "${mounts[@]}"; do
        [ "$mount" = "$item" ] && return 0
    done
    return 1
}

append_mount_to_list() {
    local list="$1"
    local item="$2"

    if [ -n "$list" ]; then
        printf '%s:%s\n' "$list" "$item"
    else
        printf '%s\n' "$item"
    fi
}

allow_cmd() {
    local path
    local real
    local mounts
    local changed=0

    require_host_runtime_for_desktop
    [ "$#" -gt 0 ] || {
        printf 'usage: agent allow PATH [PATH...]\n' >&2
        return 2
    }

    mounts="$(load_configured_mounts)"
    for path in "$@"; do
        if [ ! -d "$path" ]; then
            printf 'not a directory: %s\n' "$path" >&2
            return 2
        fi
        real="$(canonical_path "$path")"
        if mount_list_contains "$mounts" "$real"; then
            printf 'already allowed: %s\n' "$real"
            continue
        fi
        mounts="$(append_mount_to_list "$mounts" "$real")"
        changed=1
        printf 'allowed: %s\n' "$real"
    done

    if [ "$changed" -eq 1 ]; then
        write_configured_mounts "$mounts"
        printf 'config: %s\n' "$(config_file_for_mounts)"
    fi
}

config_cmd() {
    local subcmd="${1:-edit}"
    local file

    require_host_runtime_for_desktop
    file="$(config_file_for_mounts)"

    case "$subcmd" in
        path)
            printf '%s\n' "$file"
            ;;
        open)
            install -d -m 700 "$PERMISSIONS_DIR"
            if command -v xdg-open >/dev/null 2>&1; then
                xdg-open "$PERMISSIONS_DIR" >/dev/null 2>&1 &
            else
                printf '%s\n' "$PERMISSIONS_DIR"
            fi
            ;;
        edit|"")
            install -d -m 700 "$PERMISSIONS_DIR"
            if [ ! -f "$file" ]; then
                write_configured_mounts "$(load_configured_mounts)"
            fi
            if [ -n "${EDITOR:-}" ]; then
                "$EDITOR" "$file"
            else
                printf '%s\n' "$file"
            fi
            ;;
        *)
            printf 'unknown config command: %s\n' "$subcmd" >&2
            printf 'usage: agent config [edit|open|path]\n' >&2
            return 2
            ;;
    esac
}

doctor() {
    printf 'image: '
    if image_exists; then
        printf 'present (%s)\n' "$IMAGE"
    else
        printf 'missing (%s)\n' "$IMAGE"
    fi
    printf 'agent home: %s\n' "$AGENT_HOME"
    printf 'config file: %s ' "$CONFIG_FILE"
    if [ -f "$CONFIG_FILE" ]; then
        printf '(present)\n'
    else
        printf '(missing)\n'
    fi
    printf 'permissions dir: %s\n' "$PERMISSIONS_DIR"
    printf 'projects mount: %s ' "$PROJECTS_DIR"
    if [ -d "$PROJECTS_DIR" ]; then
        printf '(present)\n'
    else
        printf '(missing)\n'
    fi
    printf 'network: %s\n' "$AGENT_NETWORK"
    printf 'userns: %s\n' "$AGENT_USERNS"
    printf 'sandbox mode: %s\n' "$AGENT_SANDBOX"
    sandbox_lease_summary
    printf 'broker socket: %s ' "$BROKER_SOCKET"
    if [ -S "$BROKER_SOCKET" ]; then
        printf '(present)\n'
    else
        printf '(missing)\n'
    fi
    printf 'adb server: '
    if command -v adb >/dev/null 2>&1 && adb devices >/dev/null 2>&1; then
        printf 'reachable\n'
    else
        printf 'not reachable\n'
    fi
}

cmd="${1:-}"
case "$cmd" in
    build-image)
        build_image
        ;;
    self-update)
        shift
        self_update "$@"
        ;;
    setup-android-sdk)
        shift
        setup_android_sdk "$@"
        ;;
    broker-start)
        start_broker
        ;;
    shell)
        shift
        run_container bash "$@"
        ;;
    codex)
        shift
        run_container codex "$@"
        ;;
    desktop)
        shift
        desktop_cmd "$@"
        ;;
    allow)
        shift
        allow_cmd "$@"
        ;;
    config)
        shift
        config_cmd "$@"
        ;;
    exec)
        shift
        [ $# -gt 0 ] || {
            usage >&2
            exit 2
        }
        run_container "$@"
        ;;
    sandbox)
        shift
        sandbox_cmd="${1:-status}"
        case "$sandbox_cmd" in
            off|disable)
                shift
                sandbox_disable "${1:-240m}"
                ;;
            on|enable)
                shift
                sandbox_enable
                ;;
            status|"")
                sandbox_lease_summary
                ;;
            *)
                printf 'unknown sandbox command: %s\n' "$sandbox_cmd" >&2
                usage >&2
                exit 2
                ;;
        esac
        ;;
    doctor)
        doctor
        ;;
    ""|-h|--help|help)
        usage
        ;;
    *)
        printf 'unknown command: %s\n' "$cmd" >&2
        usage >&2
        exit 2
        ;;
esac
