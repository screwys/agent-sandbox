#!/usr/bin/env python3
import json
import os
import re
import selectors
import socket
import subprocess
import sys
import threading
from pathlib import Path


DEFAULT_ALLOWED_UNITS = {
    "igloo.service",
    "igloo-nginx.service",
    "rsshub.service",
    "radicale.service",
    "todo-sync.service",
}
ALLOWED_SERVICE_ACTIONS = {
    "start",
    "stop",
    "restart",
    "status",
    "is-active",
    "is-failed",
}
EXIT_MARKER = b"\n__AGENT_EXIT__="


class RequestError(Exception):
    pass


def socket_path() -> Path:
    override = os.environ.get("AGENT_BROKER_SOCKET")
    if override:
        return Path(override)
    runtime_dir = os.environ.get("XDG_RUNTIME_DIR")
    if not runtime_dir:
        raise RequestError("XDG_RUNTIME_DIR is not set")
    return Path(runtime_dir) / "agent-sandbox" / "broker.sock"


def allowed_units() -> set[str]:
    raw = os.environ.get("AGENT_HOST_ALLOWED_UNITS", "")
    extra = {unit.strip() for unit in re.split(r"[\s,:]+", raw) if unit.strip()}
    return DEFAULT_ALLOWED_UNITS | extra


def ensure_allowed_unit(unit: str) -> None:
    if unit not in allowed_units():
        raise RequestError(f"unit is not allowed: {unit}")


def systemctl_user(*args: str) -> list[str]:
    return ["systemctl", "--user", *args]


def journalctl_user(unit: str, *, follow: bool, lines: str) -> list[str]:
    ensure_allowed_unit(unit)
    cmd = ["journalctl", "--user", "-u", unit, "-n", lines, "--no-pager"]
    if follow:
        cmd.append("-f")
    return cmd


def parse_line_count(raw: str) -> str:
    if not re.fullmatch(r"[0-9]{1,4}", raw):
        raise RequestError(f"invalid line count: {raw}")
    return raw


def command_plan(argv: list[str]) -> list[list[str]]:
    if not argv:
        raise RequestError("missing command")

    if argv[0] != "service":
        raise RequestError(f"command group is not allowed: {argv[0]}")
    if len(argv) < 2:
        raise RequestError("usage: service ACTION [UNIT]")

    action = argv[1]
    if action == "daemon-reload":
        if len(argv) != 2:
            raise RequestError("usage: service daemon-reload")
        return [systemctl_user("daemon-reload")]
    if action == "logs":
        if len(argv) < 3:
            raise RequestError("usage: service logs UNIT [--follow] [-n LINES]")
        unit = argv[2]
        follow = False
        lines = "120"
        rest = argv[3:]
        i = 0
        while i < len(rest):
            if rest[i] == "--follow":
                follow = True
                i += 1
            elif rest[i] == "-n" and i + 1 < len(rest):
                lines = parse_line_count(rest[i + 1])
                i += 2
            else:
                raise RequestError(f"unsupported logs argument: {rest[i]}")
        return [journalctl_user(unit, follow=follow, lines=lines)]
    if action not in ALLOWED_SERVICE_ACTIONS:
        raise RequestError(f"service action is not allowed: {action}")
    if len(argv) != 3:
        raise RequestError(f"usage: service {action} UNIT")
    unit = argv[2]
    ensure_allowed_unit(unit)
    return [systemctl_user(action, unit)]


def run_process(cmd: list[str], conn: socket.socket) -> int:
    conn.sendall(("[broker] " + " ".join(cmd) + "\n").encode())
    proc = subprocess.Popen(cmd, stdout=subprocess.PIPE, stderr=subprocess.STDOUT)
    assert proc.stdout is not None
    selector = selectors.DefaultSelector()
    selector.register(proc.stdout, selectors.EVENT_READ)
    try:
        while True:
            events = selector.select(timeout=0.2)
            for key, _ in events:
                data = os.read(key.fileobj.fileno(), 8192)
                if not data:
                    selector.unregister(key.fileobj)
                    return proc.wait()
                conn.sendall(data)
            if proc.poll() is not None and not selector.get_map():
                return proc.returncode
    except (BrokenPipeError, ConnectionResetError):
        proc.terminate()
        try:
            proc.wait(timeout=2)
        except subprocess.TimeoutExpired:
            proc.kill()
        return 130


def handle(conn: socket.socket) -> None:
    code = 1
    try:
        raw = b""
        while not raw.endswith(b"\n"):
            chunk = conn.recv(4096)
            if not chunk:
                break
            raw += chunk
            if len(raw) > 65536:
                raise RequestError("request is too large")
        request = json.loads(raw.decode("utf-8"))
        argv = request.get("argv")
        if not isinstance(argv, list) or not all(isinstance(arg, str) for arg in argv):
            raise RequestError("request must contain string argv list")
        for cmd in command_plan(argv):
            code = run_process(cmd, conn)
            if code != 0:
                break
    except Exception as exc:
        conn.sendall(f"agent-broker: {exc}\n".encode("utf-8", "replace"))
        code = 2
    finally:
        try:
            conn.sendall(EXIT_MARKER + str(code).encode() + b"\n")
        except OSError:
            pass
        conn.close()


def serve() -> int:
    path = socket_path()
    path.parent.mkdir(mode=0o700, parents=True, exist_ok=True)
    if path.exists():
        path.unlink()

    server = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    server.bind(str(path))
    os.chmod(path, 0o600)
    server.listen(8)
    print(f"agent-broker listening on {path}", flush=True)

    try:
        while True:
            conn, _ = server.accept()
            threading.Thread(target=handle, args=(conn,), daemon=True).start()
    finally:
        server.close()


def usage() -> None:
    print("usage: agent-broker serve", file=sys.stderr)


if __name__ == "__main__":
    if len(sys.argv) == 2 and sys.argv[1] == "serve":
        raise SystemExit(serve())
    usage()
    raise SystemExit(2)
